{
  "name": "agentyard",
  "version": "0.1.2",
  "description": "Adapter-based MCP orchestrator for AI coding agent sessions (Agent of Empires, Claude Code transcripts).",
  "type": "module",
  "license": "MIT",
  "author": "Sam McTaggart <sam.mctaggart@gmail.com>",
  "homepage": "https://github.com/wannabefro/agentyard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wannabefro/agentyard.git"
  },
  "bugs": {
    "url": "https://github.com/wannabefro/agentyard/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "agent-orchestration",
    "claude-code",
    "agent-of-empires",
    "tmux",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "agentyard": "src/index.ts"
  },
  "files": [
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "fuse.js": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
